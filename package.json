{
  "name": "mochi",
  "version": "0.1.0",
  "description": "🪼 Mochi —— 住在屏幕角落的情绪陪伴小兽，安静、不打扰的桌面伙伴",
  "main": "src/main.js",
  "author": "Mochi",
  "license": "MIT",
  "homepage": "https://jellymate-amber.vercel.app",
  "repository": {
    "type": "git",
    "url": "https://github.com/1ivy403/jellymate-desktop"
  },
  "keywords": [
    "desktop",
    "companion",
    "electron",
    "macos",
    "productivity",
    "focus",
    "jellyfish"
  ],
  "scripts": {
    "start": "electron .",
    "test": "node test/renderer.test.js",
    "build": "electron-builder --mac --publish never"
  },
  "devDependencies": {
    "electron": "^33.4.11",
    "electron-builder": "^26.0.0",
    "jsdom": "^29.1.1",
    "puppeteer-core": "^25.1.0"
  },
  "build": {
    "appId": "com.mochi.app",
    "productName": "Mochi",
    "copyright": "Copyright © 2026 Mochi",
    "mac": {
      "category": "public.app-category.lifestyle",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        },
        {
          "target": "dmg",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.icns",
      "minimumSystemVersion": "12.0"
    },
    "dmg": {
      "title": "Mochi 安装",
      "background": "assets/dmg-bg.png",
      "window": {
        "width": 540,
        "height": 380
      }
    },
    "files": [
      "src/**/*",
      "assets/**/*"
    ]
  }
}